SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password-no-spaces
FROM_EMAIL=

# If app passwords always return 535: set SMTP_USE_OAUTH2=true and fill the three GOOGLE_OAUTH_* vars.
# Get a refresh token via https://developers.google.com/oauthplayground/ scope https://mail.google.com/
SMTP_USE_OAUTH2=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
